<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TempTrimmer</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand navbar-dark bg-dark px-3 mb-4">
        <a class="navbar-brand fw-semibold" asp-page="/Index">
            <img src="~/icon.png" alt="" width="32" height="32" class="me-2" style="border-radius:6px;" />
            TempTrimmer
        </a>
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" asp-page="/Index">Dashboard</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Config">Configuration</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Logs">Logs</a>
            </li>
        </ul>
    </nav>

    <main class="container-fluid px-4 pb-5">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
