{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TempTrimmer": {
    "PathBase": "/AcsSolutions.TempTrimmer",
    "MaxAge": "3.00:00:00",
    "MaxTotalSizeMb": 1024,
    "TempPath": "%TEMP%",
    "ApiKey": "",
    "ScanInterval": "00:15:00",
    "ExcludedFolders": [ "/jobs*" ],
    "ExcludedFiles": [ "/applicationhost.config" ],
    "DryRun": true
  }
}
